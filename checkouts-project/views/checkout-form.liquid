<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nieuwe checkout</title>
  </head>
  <body>
    <header>
      <h1>Nieuwe checkout</h1>
      <a href="/checkouts">Alle checkouts</a>
    </header>
    <main>
      <form method="POST" action="/checkouts">
        <fieldset>
          <legend>Vul je checkout in</legend>
          <label for="datum">Datum</label>
          <input type="date" id="datum" name="datum" required>
          <label for="reflectie">Reflectie</label>
          <textarea id="reflectie" name="reflectie" required></textarea>
          <button type="submit">Opslaan</button>
        </fieldset>
      </form>
    </main>
  </body>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #1a1a1a;
      color: #f5f5f5;
      font-family: sans-serif;
      line-height: 1.6;
      padding: 2rem;
      max-width: 50rem;
      margin: 0 auto;
    }

    h1 {
      color: #800020;
      margin-bottom: 2rem;
    }

    label {
      display: block;
      margin-top: 1rem;
    }

    input,
    textarea {
      width: 100%;
      padding: 0.5rem;
      background: #2a2a2a;
      color: #f5f5f5;
      border: 1px solid #800020;
      font-size: 1rem;
    }

    textarea {
      min-height: 8rem;
      resize: vertical;
    }

    button {
      margin-top: 1rem;
      padding: 0.5rem 1rem;
      background: #800020;
      color: #f5f5f5;
      border: none;
      cursor: pointer;
    }

    button:hover {
      background: #600018;
    }

    fieldset {
      padding: 3em;
      border-color: #600018;
    }
    a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: #800020;
      color: #f5f5f5;
      text-decoration: none;
      margin-bottom: 2rem;
    }

    a:hover {
      background: #600018;
    }
  </style>
</html>
